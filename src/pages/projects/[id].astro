---
import { getEntry, render, getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectTags from "@components/projects/ProjectTags.astro";
import { Image } from "astro:assets";
import { Github, ExternalLink, CalendarDays } from "@lucide/astro";
import formatDate from "../../utils/date";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: {
      id: project.id,
    },
  }));
}

const { id } = Astro.params;
if (!id) return Astro.redirect("/404");
const project = await getEntry("projects", id!);
if (!project) return Astro.redirect("/404");

const { image, alt, date, title, tags, github, live } = project!.data;
const { Content } = await render(project!);
---

<Layout>
  <div class="mx-auto max-w-2xl space-y-10 px-6 py-22">
    <!-- banner image -->
    <div class="overflow-hidden">
      <Image
        src={image}
        alt={alt}
        class="aspect-video rounded-xl"
        style={`view-transition-name: proj-img-${id}`}
      />
    </div>
    <!-- basic info -->
    <h1
      class="xs:text-3xl text-accent font-bold sm:text-5xl lg:text-6xl"
      style={`view-transition-name: proj-h-${id}`}
    >
      {title}
    </h1>
    <div class="flex items-center gap-2">
      <span class="text-subtle flex items-center gap-2">
        <CalendarDays size={18} />
        {formatDate(date)}
      </span>
      {
        github && (
          <a
            href={github}
            rel="noopener noreferrer"
            target="_blank"
            class="text-accent"
          >
            <Github size={18} />
          </a>
        )
      }
      {
        live && (
          <a
            href={live}
            rel="noopener noreferrer"
            target="_blank"
            class="text-accent"
          >
            <ExternalLink size={18} />
          </a>
        )
      }
    </div>
    <!-- Tags -->
    <div class="flex items-center justify-start gap-x-2">
      <ProjectTags tags={tags} />
    </div>
    <!-- mardown body -->
    <div
      class="prose prose-invert prose-h1:font-normal prose-h2:font-normal prose-h3:font-normal prose-h1:text-4xl prose-h1:text-accent prose-h2:text-accent prose-h3:text-accent prose-a:text-accent border-border mt-6 max-w-2xl border-t pt-6"
    >
      <Content />
    </div>
  </div>
</Layout>
