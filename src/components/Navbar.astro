---
import { Menu, X } from "@lucide/astro";
import ThemeSwitcher from "@components/home/ThemeSwitcher.astro";

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);

const crumbs = segments.map((seg, i) => ({
  label: seg,
  href: "/" + segments.slice(0, i + 1).join("/"),
}));
---

<!-- Navbar -->
<nav
  class="fixed inset-x-0 z-10 mx-auto flex h-15 max-w-6xl items-center justify-between bg-transparent px-6 font-semibold backdrop-blur-sm"
>
  <!-- Breadcrumbs -->
  <div class="flex items-center gap-1">
    <a href="/" class="text-accent">~</a>
    {
      crumbs.map((crumb, i) => (
        <>
          <span>/</span>
          {i === crumbs.length - 1 ? (
            <span>{crumb.label}</span>
          ) : (
            <a href={crumb.href} class="hover:text-accent">
              {crumb.label}
            </a>
          )}
        </>
      ))
    }
    <div class="bg-accent h-4 w-2 animate-pulse [animation-duration:3s]"></div>
  </div>
  <!-- Navlinks -->
  <ul class="hidden items-center gap-8 md:flex">
    <li><a href="/about" class="hover:text-accent">About</a></li>
    <li><a href="/projects" class="hover:text-accent">Projects</a></li>
  </ul>
  <!-- Sidebar trigger-->
  <button id="sidebar-trigger" class="block md:hidden">
    <Menu />
  </button>
</nav>

<!-- Backdrop for sidebar -->
<div id="sidebar-backdrop"></div>
<!-- Sidebar -->
<aside id="sidebar" class="toggle-sidebar">
  <div
    class="border-border text-accent mb-8 flex items-center justify-between border-b py-2 text-2xl"
  >
    Navigation
    <X id="sidebar-close" size={30} class="text-text shrink-0" />
  </div>
  <div class="flex flex-col space-y-10">
    <nav class="flex flex-col text-2xl">
      <a href="/" class="hover:bg-fg rounded px-2 py-1">Home</a>
      <a href="/about" class="hover:bg-fg rounded px-2 py-1">About</a>
      <a href="/projects" class="hover:bg-fg rounded px-2 py-1">Projects</a>
    </nav>
    <ThemeSwitcher />
  </div>
</aside>

<script src="../scripts/navbar.ts"></script>

<style>
  .toggle-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: clamp(240px, 55vw, 270px);
    height: 100vh;
    background: var(--rosepine-fg);
    transform: translateX(100%);
    transition: transform 0.3s ease-in-out;
    padding-left: 1rem;
    padding-right: 1rem;
    padding-top: 1rem;
    z-index: 30;
  }
  .toggle-sidebar.open {
    transform: translateX(0);
  }
  #sidebar-backdrop {
    position: fixed;
    width: 100vw;
    height: 100vh;
    opacity: 0;
    transition: all 0.3s ease-in-out;
    pointer-events: none;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    z-index: 20;
  }
  #sidebar-backdrop.open {
    opacity: 1;
    pointer-events: all;
    width: 100vw;
    height: 100vh;
  }
</style>
