---
import { Github, Mail } from "@lucide/astro";
---

<footer
  class="xs:w-[85vw] mx-auto mt-30 mb-6 flex h-15 items-center justify-between rounded-lg bg-(--fg) px-4 sm:w-[88vw] md:w-[85vw] lg:w-[75vw]"
>
  <span>&copy; 2026 Slade</span>
  <div class="flex items-center gap-2">
    <a
      class="cursor-pointer hover:text-(--accent)"
      href="https://github.com/thecentinol"
      rel="noopener noreferrer"
      target="_blank"
    >
      <Github />
    </a>
    <a
      class="cursor-pointer hover:text-(--accent)"
      href="mailto:centinol@proton.me"
      rel="noopener noreferrer"
      target="_blank"
    >
      <Mail />
    </a>
  </div>
</footer>
