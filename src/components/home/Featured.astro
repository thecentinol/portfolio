---
import { Star, ArrowRight, Tag } from "@lucide/astro";
import { getCollection, type CollectionEntry } from "astro:content";

const projects = await getCollection(
  "projects",
  ({ data }: CollectionEntry<"projects">) => data.featured === true,
);
type Project = CollectionEntry<"projects">;

const tagColors = [
  "text-[#8839ef]",
  "text-[#ef9f76]",
  "text-[#40a02b]",
  "text-[#179299]",
  "text-[#1e66f5]",
  "text-[#dc8a78]",
  "text-[#d20f39]",
];
---

<section class="mx-auto mb-8 max-h-screen w-[75vw] space-y-10">
  <div class="flex items-center justify-between">
    <h2 class="flex items-center gap-2 text-4xl font-bold">
      <Star size={30} class="text-(--accent)" />
      Featured Projects
    </h2>
    <a
      href="/projects"
      class="group flex cursor-pointer items-center gap-2 text-sm text-(--accent) underline decoration-dashed underline-offset-4"
    >
      VIEW ALL
      <ArrowRight size={18} class="duration-300 group-hover:translate-x-1" />
    </a>
  </div>

  <div class="grid h-full w-full grid-cols-2 items-center gap-4">
    {
      projects.map((p: Project) => (
        <a
          href={`/projects/${p.slug}`}
          class="group h-120 w-full cursor-pointer rounded-xl border border-(--border) bg-(--fg) duration-400 hover:border-(--accent)"
        >
          <div class="h-[65%] rounded-t-xl bg-[#a9b4c0] p-10">
            <slot name="image" />
          </div>

          <div class="flex h-[35%] flex-col items-start justify-between p-5">
            <h3 class="text-2xl font-bold duration-300 group-hover:text-(--accent)">
              {p.data.title}
            </h3>
            <p class="font-inter text-sm text-(--text-muted)">{p.data.desc}</p>
            <div class="flex flex-nowrap items-center gap-2">
              <Tag size={18} class="shrink-0" />
              {p.data.tags.length > 5
                ? p.data.displayedTags.map((tag: Project, i: Project) => (
                    <span
                      class={`shrink-0 bg-(--tag) px-2 py-2 font-mono text-xs font-bold ${tagColors[i % tagColors.length]}`}
                    >
                      {tag}
                    </span>
                  ))
                : p.data.tags.map((tag: Project, i: Project) => (
                    <span
                      class={`shrink-0 bg-(--tag) px-2 py-2 font-mono text-xs font-bold ${tagColors[i % tagColors.length]}`}
                    >
                      {tag}
                    </span>
                  ))}
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
