---
import { Star, ArrowRight } from "@lucide/astro";
import ProjectCard from "../projects/ProjectCard.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const agentflux = await getCollection(
  "projects",
  ({ data }: CollectionEntry<"projects">) => data.title === "AgentFlux",
);
const af = agentflux[0].data;

const sermoui = await getCollection(
  "projects",
  ({ data }: CollectionEntry<"projects">) => data.title === "SermoUI",
);
const sermo = sermoui[0].data;
---

<section class="mx-auto h-screen w-[75vw]">
  <div class="flex items-center justify-between">
    <h2 class="flex items-center gap-2 text-4xl font-bold">
      <Star size={30} class="text-(--accent)" />
      Featured Projects
    </h2>
    <a
      class="group flex cursor-pointer items-center gap-2 text-sm text-(--accent) underline decoration-dashed underline-offset-4"
    >
      VIEW ALL
      <ArrowRight size={18} class="duration-300 group-hover:translate-x-1" />
    </a>
  </div>

  <div class="flex h-full w-full items-center gap-4">
    <ProjectCard title={af.title} desc={af.desc} tags={af.tags}>
      <div slot="image">
        <!-- card-v2-visual -->
        <div
          class="relative h-45 overflow-hidden rounded-lg opacity-80 transition-all duration-300 group-hover:scale-105 group-hover:opacity-100"
        >
          <!-- visual-crm -->
          <div
            class="grid h-full bg-(--bg)"
            style="grid-template-columns: 60px 1fr;"
          >
            <!-- vis-sidebar -->
            <div
              class="flex flex-col gap-1.5 border-r border-[#222] bg-[#111] px-2 py-3"
            >
              <div class="h-2 w-[70%] rounded-sm bg-blue-500"></div>
              <div class="h-2 rounded-sm bg-[#222]"></div>
              <div class="h-2 rounded-sm bg-[#222]"></div>
              <div class="h-2 rounded-sm bg-[#222]"></div>
            </div>

            <!-- vis-main -->
            <div class="flex flex-col gap-2 p-3">
              <!-- vis-header-bar -->
              <div
                class="flex h-5 items-center gap-1.5 rounded-[3px] bg-[#1a1a2e] px-2"
              >
                <div class="h-1.5 w-1.5 rounded-full bg-blue-500"></div>
                <div class="h-1 w-15 rounded-sm bg-[#1d3a6e]"></div>
              </div>

              <!-- vis-table -->
              <div class="flex flex-col gap-0.75">
                <!-- header row -->
                <div
                  class="flex h-4 items-center gap-1 rounded-sm bg-[#1a1a2e] px-1.5"
                >
                  <div class="h-1.5 w-[20%] rounded-[1px] bg-blue-700"></div>
                  <div class="h-1.5 w-[30%] rounded-[1px] bg-blue-700"></div>
                  <div class="h-1.5 w-[15%] rounded-[1px] bg-blue-700"></div>
                  <div class="h-1.5 w-[25%] rounded-[1px] bg-blue-700"></div>
                </div>

                <!-- data rows -->
                <div
                  class="flex h-4 items-center gap-1 rounded-sm bg-[#161616] px-1.5"
                >
                  <div class="h-1.5 w-[20%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[30%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[15%] rounded-[1px] bg-green-900"></div>
                  <div class="h-1.5 w-[25%] rounded-[1px] bg-[#2a2a2a]"></div>
                </div>

                <div
                  class="flex h-4 items-center gap-1 rounded-sm bg-[#161616] px-1.5"
                >
                  <div class="h-1.5 w-[20%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[30%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[15%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[25%] rounded-[1px] bg-[#2a2a2a]"></div>
                </div>

                <div
                  class="flex h-4 items-center gap-1 rounded-sm bg-[#161616] px-1.5"
                >
                  <div class="h-1.5 w-[20%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[30%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[15%] rounded-[1px] bg-green-900"></div>
                  <div class="h-1.5 w-[25%] rounded-[1px] bg-[#2a2a2a]"></div>
                </div>

                <div
                  class="flex h-4 items-center gap-1 rounded-sm bg-[#161616] px-1.5"
                >
                  <div class="h-1.5 w-[20%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[30%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[15%] rounded-[1px] bg-[#2a2a2a]"></div>
                  <div class="h-1.5 w-[25%] rounded-[1px] bg-[#2a2a2a]"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </ProjectCard>
    <ProjectCard title={sermo.title} desc={sermo.desc} tags={sermo.tags}>
      <div slot="media"></div>
    </ProjectCard>
  </div>
</section>
