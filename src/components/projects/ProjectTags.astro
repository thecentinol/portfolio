---
import { Tag } from "@lucide/astro";
import { getRandomTagColor } from "../../utils/tagColor";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
const tagColors =
  tags.reduce(
    (acc, tag) => {
      acc[tag] = getRandomTagColor();
      return acc;
    },
    {} as Record<string, string>,
  ) || {};
---

<div class="flex max-h-8 flex-wrap gap-2 overflow-hidden">
  <Tag size={18} class="shrink-0" />
  {
    tags.map((tag) => (
      <span
        class="shrink-0 rounded px-2 py-1 text-xs font-bold"
        style={{
          color: `var(--color-${tagColors[tag]})`,
          background: `color-mix(in srgb, var(--color-${tagColors[tag]}) 15%, transparent)`,
        }}
      >
        {tag}
      </span>
    ))
  }
</div>
