---
import { Tag } from "@lucide/astro";

interface Props {
  title: string;
  desc: string;
  tags: string[];
  github?: string;
}

const { title, desc, tags, github } = Astro.props;

const tagColors = [
  "text-[#8839ef]",
  "text-[#ef9f76]",
  "text-[#40a02b]",
  "text-[#179299]",
  "text-[#1e66f5]",
  "text-[#dc8a78]",
  "text-[#d20f39]",
];
---

<div
  class="group h-120 w-full rounded-xl border border-(--border) bg-(--fg) duration-400 hover:border-(--accent)"
>
  <div class="h-[65%] rounded-t-xl bg-[#a9b4c0] p-10">
    <slot name="image" />
  </div>

  <div class="flex h-[35%] flex-col items-start justify-between p-5">
    <h3 class="text-2xl font-bold duration-300 group-hover:text-(--accent)">
      {title}
    </h3>
    <p class="font-inter text-sm text-(--text-muted)">{desc}</p>
    <div class="flex flex-nowrap items-center gap-2">
      <Tag size={18} class="shrink-0" />
      {
        tags.map((tag, i) => (
          <span
            class={`shrink-0 bg-(--tag) px-2 py-2 font-mono text-xs font-bold ${tagColors[i % tagColors.length]}`}
          >
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
